### Test Case 5: Mixed Known and Unknown Events

```javascript
describe('when stream has mixed known and unknown events', () => {
  it('applies only known events and ignores unknown', async () => {
    const { appendStream, spies } = createMockAppendEnabledStream({
      existingEvents: [
        createStoredEvent('input-logged', { value: 'known-1' }, { streamId: STREAM_ID, version: 1 }),
        createStoredEvent('some-other-event', { data: 'ignored' }, { streamId: STREAM_ID, version: 2 }),
        createStoredEvent('input-logged', { value: 'known-2' }, { streamId: STREAM_ID, version: 3 }),
        createStoredEvent('yet-another-unknown', { data: 'also-ignored' }, { streamId: STREAM_ID, version: 4 }),
      ],
    })

    const result = await doSomething(appendStream)(STREAM_ID, 'new-input')

    expect(spies.save).to.have.been.calledOnce

    await result.fold(
      error => { throw new Error(`Should not fail: ${error.message}`) },
      ({ entity }) => {
        expect(entity.inputCount).to.equal(2)
        expect(entity.lastInput).to.equal('known-2')
      },
    )
  })
})
```

## Verifying Appended Events

```javascript
describe('verifying appended events', () => {
  it('verifies events are appended with correct structure', async () => {
    const { appendStream, getAppendedEvents, spies } = createMockAppendEnabledStream({
      existingEvents: [],
    })

    await doSomething(appendStream)(STREAM_ID, 'test-value')

    expect(spies.appendEvents).to.have.been.calledOnce
    expect(spies.appendEvents).to.have.been.calledWith(sinon.match.array)

    const [appendedEvent] = getAppendedEvents()
    expect(appendedEvent).to.have.property('type', 'input-logged')
    expect(appendedEvent).to.have.property('payload')
    expect(appendedEvent.payload).to.eql({ value: 'test-value' })

    // Domain events have no metaData
    expect(appendedEvent).to.not.have.property('metaData')
    expect(appendedEvent).to.not.have.property('detail')
  })
})
```

## Verifying Save is Called

```javascript
describe('verifying save behavior', () => {
  it('calls save after appending events', async () => {
    const { appendStream, spies } = createMockAppendEnabledStream({ existingEvents: [] })

    await doSomething(appendStream)(STREAM_ID, 'input')

    expect(spies.save).to.have.been.calledOnce
    expect(spies.appendEvents).to.have.been.calledBefore(spies.save)
  })

  it('propagates save errors', async () => {
    const saveError = new Error('Database connection failed')
    const { appendStream } = createMockAppendEnabledStream({
      existingEvents: [],
      saveError,
    })

    const result = await doSomething(appendStream)(STREAM_ID, 'input')

    await result.fold(
      error => expect(error.message).to.equal('Database connection failed'),
      () => { throw new Error('Should have failed') },
    )
  })
})
```

## Testing Query Actions

```javascript
import { getSomething } from '../src/actions/get-something.js'
import { createMockReadOnlyStream, createStoredEvent } from '@rinkkasatiainen/cfb-event-sourcing-testing'

const STREAM_ID = 'test-stream'

describe('getSomething action', () => {
  it('replays and returns query result', async () => {
    const { readOnlyStream } = createMockReadOnlyStream({
      existingEvents: [
        createStoredEvent('input-logged', { value: 'hello' }, { streamId: STREAM_ID, version: 1 }),
      ],
    })

    const result = await getSomething(readOnlyStream)(STREAM_ID)

    await result.fold(
      () => { throw new Error('Should not fail') },
      data => expect(data.lastInput).to.equal('hello'),
    )
  })
})
```

## Testing Entity Modules Directly

Entity tests need no stream mocks. Import `createStoredEvent` for handler fixtures:

```javascript
import { InputLogger } from '../src/entities/input-logger.js'
import { createStoredEvent } from '@rinkkasatiainen/cfb-event-sourcing-testing'

describe('InputLogger entity', () => {
  describe('empty()', () => {
    it('returns initial state', () => {
      expect(InputLogger.empty()).to.eql({
        lastInput: null,
        inputCount: 0,
      })
    })
  })

  describe('eventHandlers', () => {
    it('handles input-logged event', () => {
      const state = InputLogger.empty()
      const event = createStoredEvent('input-logged', { value: 'test' })

      const newState = InputLogger.eventHandlers['input-logged'](state, event)

      expect(newState.lastInput).to.equal('test')
      expect(newState.inputCount).to.equal(1)
    })

    it('dispatches on event.metaData.type and reads event.payload', () => {
      const event = {
        metaData: { streamId: 's', version: 1, type: 'input-logged' },
        payload: { value: 'x' },
      }
      const newState = InputLogger.eventHandlers['input-logged'](InputLogger.empty(), event)
      expect(newState.lastInput).to.equal('x')
    })

    it('does not mutate original state', () => {
      const state = InputLogger.empty()
      const event = createStoredEvent('input-logged', { value: 'test' })

      const newState = InputLogger.eventHandlers['input-logged'](state, event)

      expect(state.lastInput).to.be.null
      expect(newState.lastInput).to.equal('test')
    })
  })

  describe('commands', () => {
    it('logInput returns event with type and payload', () => {
      const events = InputLogger.logInput(InputLogger.empty(), 'my-input')

      expect(events).to.have.length(1)
      expect(events[0]).to.eql({
        type: 'input-logged',
        payload: { value: 'my-input' },
      })
    })

    it('commands return only type and payload (no metaData)', () => {
      const events = InputLogger.logInput(InputLogger.empty(), 'input')

      expect(events[0]).to.have.all.keys('type', 'payload')
      expect(events[0]).to.not.have.property('metaData')
      expect(events[0]).to.not.have.property('detail')
    })
  })
})
```

## Don'ts

- ❌ Don't use Jest — use Mocha, Chai, Sinon
- ❌ Don't hand-roll mock streams in capability packages — use `cfb-event-sourcing-testing`
- ❌ Don't use legacy `{ detail: { metadata, data } }` event shape in tests
- ❌ Don't assert `data` on domain events — use `payload`
- ❌ Don't pass `streamOptions` in action tests — mocks implement core ports directly
- ❌ Don't test RDS/AWS infrastructure in capability `domain` unit tests
- ❌ Don't use `createMockAppendEnabledStream` for query action tests
- ❌ Don't forget `sinon.restore()` in `afterEach`

## Do's

- ✅ Import mocks from `@rinkkasatiainen/cfb-event-sourcing-testing`
- ✅ Call actions as `action(appendStream)(streamId, input)` or `action(readOnlyStream)(streamId)`
- ✅ Use `createStoredEvent` with `{ streamId, version, type }` in `metaData`
- ✅ Verify appended events are `{ type, payload }` without `metaData`
- ✅ Test entity modules separately from actions
- ✅ Use `sinon-chai` for spy/stub assertions
- ✅ Use `Eventually.fold()` to assert action results
- ✅ Test replay order when multiple known events exist
